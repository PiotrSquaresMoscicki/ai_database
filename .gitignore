# ==========================================
# 1. Terraform (Local State & Caching)
# ==========================================
# Ignore local provider plugins and workspaces
**/.terraform/

# Ignore local state files (CRITICAL: These contain plaintext data)
*.tfstate
*.tfstate.*

# Ignore crash logs and local overrides
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# (Note: .terraform.lock.hcl is NOT ignored as it pins provider versions)


# ==========================================
# 2. SOPS & Security (CRITICAL)
# ==========================================
# Never commit the plaintext secrets file before encryption
secrets.json

# Ignore temporary decrypted files created by SOPS or developers
*.dec.json
*.dec.yaml
*.dec.yml

# Safety catch for long-lived Google Cloud service account keys 
# (You are using WIF, but this prevents accidental local key leaks)
*-key.json
application_default_credentials.json


# ==========================================
# 3. Node.js & Vite Application
# ==========================================
